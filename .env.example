# Credit Risk AI Workflow — Environment Variables
# Copy this file to .env and fill in your API keys.

# OpenAI API key (required for GPT-4o communication layer)
OPENAI_API_KEY=sk-your-key-here

# Anthropic API key (optional, for Claude as alternative LLM)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model selection (defaults shown)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
GRADING_MODEL=gpt-4o

# Safety thresholds
UNCERTAINTY_THRESHOLD=0.35
DISPARATE_IMPACT_THRESHOLD=0.80
MAX_API_SPEND_USD=30.00

# Paths (defaults work if you run from repo root)
DATA_DIR=data/
RESULTS_DIR=benchmarks/results/
MODEL_PATH=data/processed/xgboost_model.joblib
